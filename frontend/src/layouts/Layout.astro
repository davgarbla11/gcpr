---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/logo_ritsi.png" />
		<title>{title} | C.F. GCPR</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Exo:wght@400;500;600&family=Raleway:wght@700;900&display=swap" rel="stylesheet">
	</head>
	
	<body class="bg-neutral-950 text-neutral-200 font-exo min-h-screen flex flex-col selection:bg-ritsi/30 selection:text-white">
		
		<header class="sticky top-0 z-50 bg-neutral-900/80 backdrop-blur-md border-b-2 border-ritsi shadow-lg">
			<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
				
				<div class="flex items-center gap-3">
					<img src="/logo_ritsi.png" alt="Logo RITSI" class="h-10 w-auto object-contain" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
					<h1 class="hidden font-raleway font-black text-2xl tracking-tight text-white logo-fallback">
						<span class="text-ritsi">Comision F.</span> GCPR
					</h1>
				</div>

				<nav id="user-nav" class="hidden items-center gap-4">
					<span id="user-email" class="text-sm font-medium text-neutral-400 hidden sm:block"></span>
					<button id="logout-btn" class="bg-neutral-800 hover:bg-neutral-700 text-white text-sm font-semibold py-2 px-4 rounded-lg transition-colors border border-neutral-700">
						Salir
					</button>
				</nav>

			</div>
		</header>

		<main class="flex-grow flex flex-col relative">
			<slot />
		</main>

		<script>
			// Lógica global para pintar el usuario y cerrar sesión
			document.addEventListener('DOMContentLoaded', () => {
				const token = localStorage.getItem('pitsi_token');
				const userEmail = localStorage.getItem('pitsi_email');
				const userNav = document.getElementById('user-nav');
				const emailSpan = document.getElementById('user-email');
				const logoutBtn = document.getElementById('logout-btn');

				if (token && userNav && emailSpan) {
					userNav.classList.remove('hidden');
					userNav.classList.add('flex');
					emailSpan.textContent = userEmail;
				}

				if (logoutBtn) {
					logoutBtn.addEventListener('click', () => {
						localStorage.removeItem('pitsi_token');
						localStorage.removeItem('pitsi_email');
						window.location.href = '/';
					});
				}
			});
		</script>
	</body>
</html>