---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Eventos">
    <div class="max-w-4xl mx-auto w-full p-4 sm:p-6 lg:p-8 mt-4 sm:mt-6 relative z-10">
        
        <div class="flex justify-between items-center mb-10">
            <div>
                <h2 class="text-4xl md:text-5xl font-raleway font-black text-white tracking-tight drop-shadow-md">
                    Eventos Activos
                </h2>
                <p class="text-neutral-400 mt-2 font-medium">Selecciona un evento para entrar a su contador</p>
            </div>
            <button id="logout-btn" class="bg-neutral-800 hover:bg-neutral-700 text-white px-4 py-2 rounded-lg border border-neutral-700 transition-colors">
                Cerrar sesión
            </button>
        </div>

        <div id="events-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <p class="text-center text-neutral-500 col-span-full py-10 animate-pulse">Cargando eventos...</p>
        </div>

    </div>
</Layout>

<script>
    const token = localStorage.getItem('pitsi_token');
    if (!token) window.location.href = '/';

    const API_BASE_URL = import.meta.env.PUBLIC_API_URL || '/api';
    const API_URL = `${API_BASE_URL}/events`;

    const loadEvents = async () => {
        try {
            const res = await fetch(API_URL, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const data = await res.json();
            
            if (data.success) {
                const container = document.getElementById('events-container');
                if (!container) return;
                
                container.innerHTML = ''; // Limpiamos

                if (data.events.length === 0) {
                    container.innerHTML = `<p class="text-center text-neutral-500 col-span-full py-10">No hay eventos creados todavía.</p>`;
                    return;
                }

                data.events.forEach((event: any) => {
                    // Creamos una tarjeta que es un enlace hacia /eventos/1, /eventos/2, etc.
                    container.innerHTML += `
                        <a href="/eventos/${event.id}" class="group bg-neutral-900/60 backdrop-blur-xl border border-neutral-800/60 rounded-3xl p-6 flex flex-col shadow-2xl relative overflow-hidden transition-transform duration-300 hover:-translate-y-1 hover:border-ritsi/50">
                            <div class="absolute inset-0 bg-gradient-to-b from-neutral-800/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                            <h3 class="text-2xl font-bold text-white mb-2 relative z-10">${event.name}</h3>
                            <p class="text-neutral-400 text-sm relative z-10">${event.description || 'Sin descripción'}</p>
                            <div class="mt-4 flex justify-end relative z-10">
                                <span class="text-ritsi group-hover:translate-x-2 transition-transform duration-300">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                </span>
                            </div>
                        </a>
                    `;
                });
            }
        } catch (error) {
            console.error("Error cargando eventos", error);
        }
    };

    document.getElementById('logout-btn')?.addEventListener('click', () => {
        localStorage.clear();
        window.location.href = '/';
    });

    loadEvents();
</script>